        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('testUser')) {",
          "  const suffix = Date.now();",
          "  pm.collectionVariables.set('testUser', 'postman_' + suffix);",
          "  pm.collectionVariables.set('testEmail', 'postman_' + suffix + '@biblioteca.cl');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8080" },
    { "key": "testPassword", "value": "ClavePostman123" }
